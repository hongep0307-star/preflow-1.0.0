<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Mac Hardened Runtime entitlements for the Electron app.

        Why each key:
        - network.client: webview/iframe load external URLs (youtube embeds,
          generic link previews). Without this, Hardened Runtime can block
          outbound HTTP and the user sees ERR_FAILED / ERR_BLOCKED_BY_RESPONSE.
        - allow-jit / allow-unsigned-executable-memory: V8 JIT and Electron's
          dynamic code generation. Required for Electron to even boot under
          Hardened Runtime.
        - disable-library-validation: load the native drag-out .node module
          which is not codesigned with the same identity as the app bundle.
        - files.user-selected.read-write: user picks files/folders via OS
          open dialog (workspace pick, library import, cover image, etc.).
        - files.downloads.read-write: write export packs into ~/Downloads.
        - automation.apple-events: optional, allows future "reveal in Finder"
          via AppleScript if needed.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
